# ============================================================
# SaathAI — Environment Variables Template
# Copy this file and fill in your actual keys:
#   server/.env  → backend keys
#   client/.env  → frontend keys
# See SETUP.md for instructions on getting each key.
# ============================================================


# ------------------------------------------------------------
# SERVER — server/.env
# ------------------------------------------------------------

# Groq API Key (Speech-to-Text via Whisper large-v3)
# Free tier — sign up at https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# Sarvam AI API Key (Chat via Sarvam-M + TTS via Bulbul v2)
# Free ₹1000 credits on signup — register at https://dashboard.sarvam.ai
SARVAM_API_KEY=sk_your_sarvam_api_key_here

# Server port (optional, defaults to 5000)
PORT=5000


# ------------------------------------------------------------
# CLIENT — client/.env
# ------------------------------------------------------------

# URL of your running backend server
# Local development:
VITE_API_URL=http://localhost:5000
# Production (replace with your Render URL):
# VITE_API_URL=https://your-service.onrender.com
